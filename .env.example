SOBAT_ENV=dev
SOBAT_CORS_ORIGINS=["*"]

# Supabase Auth. Fill these from Project Settings -> API.
SOBAT_SUPABASE_URL=https://your-project-ref.supabase.co
SOBAT_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional. Keep this server-only; never expose it in mobile/web clients.
SOBAT_SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Supabase Postgres async SQLAlchemy URL.
# Convert Supabase's connection string to asyncpg by using:
# postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SOBAT_DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres

SOBAT_TOKEN_SECRET=change-this-for-local-dev-fallback
